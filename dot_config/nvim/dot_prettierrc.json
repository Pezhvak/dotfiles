{
  "printWidth": 80,
  "proseWrap": "always",
  "overrides": [
    {
      "files": [
        "*.yaml",
        "*.yml"
      ],
      "options": {
        "printWidth": 80
      }
    },
    {
      "files": "*.md",
      "options": {
        "proseWrap": "always",
        "printWidth": 80
      }
    }
  ]
}
