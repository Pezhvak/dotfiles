export XDG_CONFIG_HOME="$HOME/.config"

export ZSH="$HOME/.oh-my-zsh"
export NVM_DIR="$HOME/.nvm"
export PNPM_HOME="$HOME/Library/pnpm"
export PYENV_ROOT="$HOME/.pyenv"

export KUBECONFIG="$HOME/.kube/config:$HOME/.kube/beenbo-config"

# Set up PATH here (not .zprofile) so non-login shells — e.g. some editor
# terminals — also see brewed tools.
eval "$(/opt/homebrew/bin/brew shellenv)"

typeset -U path
path=(
  /opt/homebrew/opt/openjdk@17/bin
  "$PYENV_ROOT/bin"
  "$HOME/.local/bin"
  "$HOME/go/bin"
  "$HOME/.bun/bin"
  "$PNPM_HOME"
  "$HOME/.opencode/bin"
  "$HOME/Documents/Flutter/bin/flutter/bin"
  $path
)
export PATH

[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"
